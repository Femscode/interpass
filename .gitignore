# Root .gitignore for Interpass Project (Python Backend + Next.js Frontend)

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# Databases (Local SQLite)
*.db
*.sqlite
*.sqlite3
backend/db/*.db
backend/db/*.sqlite
backend/db/*.sqlite3
frontend/*.db
frontend/*.sqlite
frontend/*.sqlite3

# API Secrets / Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.backup
*.env
.env.*
backend/.env
frontend/.env.local

# Python (Backend)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
*.log

# Node/Next.js (Frontend)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/
frontend/next-env.d.ts
frontend/*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.turbo/
